# =============================================================
data/
Dataset/
*Chilli*Dataset*/
datasets/raw/
*.zip
*.tar
*.tar.gz
*.tgz
*.7z
*.rar

# =============================================================
# HF / model caches
# =============================================================
.huggingface/
.cache/

# =============================================================
