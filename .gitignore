# =============================================================
logs/
*.log

# =============================================================
# Training artifacts (regenerable, large)
# =============================================================
checkpoints/
!checkpoints/.gitkeep

# =============================================================
# Generated outputs (regenerable, can be large)
# =============================================================
outputs/
!outputs/.gitkeep

# =============================================================
